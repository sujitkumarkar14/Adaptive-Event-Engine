# =============================================================================
# Adaptive Entry 360 — local environment template
# =============================================================================
# Copy this file to `.env` at the repo root and fill values for local dev.
# Never commit `.env`. Only variables prefixed with `VITE_` are exposed to the
# browser bundle; everything else is for tooling / Functions emulator only.
#
# Where to get values:
# - Firebase web config: Firebase Console → Project settings → Your apps → Web app
# - API keys for Cloud Functions: Google Cloud Console → APIs & Services →
#   Credentials (restrict keys by API + HTTP referrer / IP for web keys)
# - Secrets for deployed Functions: `firebase functions:secrets:set NAME`
# =============================================================================

# --- Firebase (client / Vite) — required for Auth, Firestore, FCM in the SPA ---
# Leave blank until you paste from Firebase Console; do not use fake “AIza…” strings.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Region for HTTPS callables (must match deployed Cloud Functions region).
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Remote Config minimum fetch interval (ms). Lower only for development.
VITE_REMOTE_CONFIG_MIN_FETCH_MS=3600000

# `true` uses mock routing in `src/services/routing.ts`. Set `false` when callables are deployed.
VITE_USE_ROUTING_MOCK=true

# Optional: base URL for venue polygon datasets. Unset = Stitch SVG + local GeoJSON fallback.
# VITE_MAPS_DATASETS_URL=

# Dashboard chaos simulator — omit in production; `true` only for staged demos.
# VITE_ENABLE_CHAOS_CONTROLLER=

# --- Firebase App Check (optional locally) ---
# If sign-in fails on localhost with App Check / reCAPTCHA, you can set:
# VITE_DISABLE_APP_CHECK=true
# Site keys come from Firebase Console → App Check (register web app).
# VITE_RECAPTCHA_SITE_KEY=
# VITE_APP_CHECK_USE_ENTERPRISE=false
# VITE_APP_ENVIRONMENT=development

# FCM web push — Firebase Console → Project settings → Cloud Messaging → Web Push certificates.
# VITE_FCM_VAPID_KEY=

# -----------------------------------------------------------------------------
# Cloud Functions / local scripts (NOT bundled into the Vite client)
# Set in Secret Manager for production; optional below for emulator-only workflows.
# -----------------------------------------------------------------------------

# MAPS_PLATFORM_KEY=
# TRANSLATION_API_KEY=
# EMERGENCY_BROADCAST_KEY=
# VERTEX_INGEST_KEY=
