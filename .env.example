# Copy to `.env` and fill for local/staging builds (Vite exposes only `VITE_*` to the client).
# Never commit real secrets; use CI secret stores for production.
# Firebase project ID must match `.firebaserc` / Firebase Console (this repo defaults to `adaptive-entry`).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=adaptive-entry
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Region for HTTPS callables (must match deployed Cloud Functions region)
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Remote Config minimum fetch interval (ms). Lower only for development.
VITE_REMOTE_CONFIG_MIN_FETCH_MS=3600000

# `true` (default) uses local mock routes in `src/services/routing.ts`. Set `false` when callables are deployed.
VITE_USE_ROUTING_MOCK=true

# Optional: Google Maps Datasets (or compatible) base URL for venue polygons. Unset = Stitch SVG + local GeoJSON fallback.
# VITE_MAPS_DATASETS_URL=

# Dashboard chaos simulator: omit in production; set "true" only for staged demos.
# VITE_ENABLE_CHAOS_CONTROLLER=

# Firebase App Check (reCAPTCHA). Omit for local dev / Vitest.
# If sign-in fails on localhost with App Check / reCAPTCHA errors, set:
# VITE_DISABLE_APP_CHECK=true
# Register a **site key per Firebase project** (staging vs production = separate projects or separate web apps).
# VITE_RECAPTCHA_SITE_KEY=
# Production/staging: often ReCaptcha Enterprise → VITE_APP_CHECK_USE_ENTERPRISE=true
# Local: ReCaptcha v3 → leave enterprise false or unset.
# VITE_APP_CHECK_USE_ENTERPRISE=false
# Optional human-readable tag (not used by runtime logic):
# VITE_APP_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Prioritize these (only VITE_* is exposed to the browser)
# -----------------------------------------------------------------------------

# FCM web push — Firebase Console → Project settings → Cloud Messaging → Web Push certificates
# VITE_FCM_VAPID_KEY=

# -----------------------------------------------------------------------------
# Cloud Functions secrets (use `firebase functions:secrets:set` in GCP; optional local copy for emulator)
# Not prefixed with VITE_ — never bundle into the client.
# -----------------------------------------------------------------------------

# MAPS_PLATFORM_KEY=
# TRANSLATION_API_KEY=
# EMERGENCY_BROADCAST_KEY=
# VERTEX_INGEST_KEY=
