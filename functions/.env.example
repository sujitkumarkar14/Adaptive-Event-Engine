# Cloud Functions runtime (set via `firebase functions:config:set` legacy or Cloud Console env for Gen2).
# Emulator: defaults match local mock backends.
# Production: prefer Secret Manager — `firebase functions:secrets:set MAPS_PLATFORM_KEY` (etc.)

# In production, set USE_MOCK_DATA=true only when intentionally using mock routing/vertex paths.
# Omitted or false in production → mock routing/vertex OFF (live or TODO bindings).
# USE_MOCK_DATA=true

# Secret names used in code (set in GCP Secret Manager for deployed functions):
# MAPS_PLATFORM_KEY       — Routes API v2, Places API (New), Distance Matrix (same restricted key)
# TRANSLATION_API_KEY     — Cloud Translation API (callable translateAlert)
# EMERGENCY_BROADCAST_KEY — HTTP emergency broadcast auth
# VERTEX_INGEST_KEY       — vertexAggregator ingest to gateLogistics
