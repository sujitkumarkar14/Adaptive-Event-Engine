rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hot path: gate pressure from Vertex aggregator / admin SDK (clients read only)
    match /gateLogistics/{gateId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Emergency mesh: clients read; writes only via Cloud Functions (Admin SDK bypasses rules)
    match /globalEvents/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Reroute policy: clients read only; writes via Cloud Functions (Admin SDK) — callable `updateRoutingPolicyLive` + automation.
    match /routingPolicy/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Segmented FCM: device token + current zone for congestion nudges (each user owns their doc).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Bottom-up priority signals: attendee owns one doc keyed by uid; staff/admin may monitor collection.
    match /userAlerts/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.role == 'staff' ||
        request.auth.token.role == 'admin'
      );
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Demo stadium slice — metadata, gates, slots, aggregates: read-only for signed-in users. Attendees are lookup-only via Cloud Functions.
    match /demoEvents/{eventId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /gates/{gateId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /slots/{slotId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /attendees/{attendeeId} {
        allow read: if false;
        allow write: if false;
      }
      match /aggregates/{docId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
